From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Aneesh Pradhan <aneeshpradhan@acm.org>
Date: Mon, 20 Jul 2026 21:05:11 -0700
Subject: [PATCH] device: add motorola-perry (XT1765) node to msm8917-mtp

Perry (Moto E4, XT1765, MSM8917) had no lk2nd device node, so lk2nd showed
'Unknown (FIXME!)' and 'Failed to find matching lk2nd device node: -1', and
'fdtdir /' in extlinux.conf could not be resolved (lk2nd_device_get_dtb_hints()
returned NULL) -> boot fell back to fastboot. Add a node mirroring its MSM8917
siblings nora/hannah: match-device 'perry' (matches lk2nd_dev.device, already
reported as 'perry' via fastboot getvar) binds the node, model clears the
FIXME, and lk2nd,dtb-files feeds the fdtdir resolver so lk2nd loads
msm8917-motorola-perry.dtb without an explicit fdt line.
---
 lk2nd/device/dts/msm8952/msm8917-mtp.dts | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/lk2nd/device/dts/msm8952/msm8917-mtp.dts b/lk2nd/device/dts/msm8952/msm8917-mtp.dts
index 43b5df7..8c6b9bd 100644
--- a/lk2nd/device/dts/msm8952/msm8917-mtp.dts
+++ b/lk2nd/device/dts/msm8952/msm8917-mtp.dts
@@ -63,6 +63,14 @@
 		};
 	};
 
+	motorola-perry {
+		model = "Motorola Moto E4 (perry) (MSM8917)";
+		compatible = "motorola,perry";
+		lk2nd,match-device = "perry";
+
+		lk2nd,dtb-files = "msm8917-motorola-perry";
+	};
+
 	xiaomi-ugglite {
 		model = "Xiaomi Redmi Note 5A (ugglite)";
 		compatible = "xiaomi,ugglite";
