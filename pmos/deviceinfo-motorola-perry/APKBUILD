# Maintainer: Project Xylitol <xylitol@users.noreply.github.com>
# Local-only pmaport (not upstream). Installs /etc/deviceinfo so boot-deploy
# emits an explicit perry fdt line instead of fdtdir / (Blocker A).
#
# Also enables systemd linger for the default image user (xylitol) so PipeWire /
# WirePlumber stay up without an open login — needed for headless SSH audio and
# harmless under Phosh (the graphical session already keeps them alive).
pkgname=deviceinfo-motorola-perry
pkgver=1
pkgrel=2
pkgdesc="perry: pin deviceinfo_dtb so boot-deploy emits fdt (not fdtdir)"
url="https://github.com/aneesh-pradhan/xylitol"
arch="noarch"
license="MIT"
source="deviceinfo"
options="!check"

package() {
	install -Dm644 "$srcdir/deviceinfo" "$pkgdir/etc/deviceinfo"
	# Equivalent to `loginctl enable-linger xylitol` (empty marker file).
	install -d "$pkgdir/var/lib/systemd/linger"
	touch "$pkgdir/var/lib/systemd/linger/xylitol"
}

sha512sums="
9901e23ef79dd8e4b33afe1a4f2d9306770d704d62d0907bede7e20d3a37f8dfdbf6e47c39001cc0825c3588a994ba5f1d8aceb8979c6a90467c85b7412659b1  deviceinfo
"
