+	mipi_dsi_msleep(&dsi_ctx, 1);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb2,
+				     0x02, 0xbf, 0x02, 0xec, 0x03, 0x06, 0x03,
+				     0x31, 0x03, 0x4d, 0x03, 0x71, 0x03, 0x89,
