+	mipi_dsi_msleep(&dsi_ctx, 1);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbd,
+				     0x01, 0x47, 0x01, 0x7e, 0x01, 0xa9, 0x01,
+				     0xed, 0x02, 0x24, 0x02, 0x25, 0x02, 0x59,
+				     0x02, 0x92);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbe,
+				     0x02, 0xb5, 0x02, 0xe6, 0x03, 0x0d, 0x03,
+				     0x3a, 0x03, 0x57, 0x03, 0x7c, 0x03, 0x94,
+				     0x03, 0xb2);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbf, 0x03, 0xde, 0x03, 0xe7);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf0, 0x55, 0xaa, 0x52, 0x08, 0x00);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xd9, 0x01, 0x01, 0x10);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x51, 0xcc);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x53, 0x2c);
