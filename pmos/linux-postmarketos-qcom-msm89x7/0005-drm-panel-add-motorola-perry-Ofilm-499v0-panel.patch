+
+static int ofilm_499_v0_off(struct ofilm_499_v0 *ctx)
+{
+	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi };
+
+	mipi_dsi_dcs_set_display_off_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 20);
+	mipi_dsi_dcs_enter_sleep_mode_multi(&dsi_ctx);
+	mipi_dsi_msleep(&dsi_ctx, 120);
+
+	return dsi_ctx.accum_err;
+}
+
+static int ofilm_499_v0_prepare(struct drm_panel *panel)
+{
+	struct ofilm_499_v0 *ctx = to_ofilm_499_v0(panel);
+	struct device *dev = &ctx->dsi->dev;
+	int ret;
+
+	ofilm_499_v0_reset(ctx);
+
+	ret = ofilm_499_v0_on(ctx);
+	if (ret < 0) {
+		dev_err(dev, "Failed to initialize panel: %d\n", ret);
+		gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+		return ret;
+	}
+
+	return 0;
+}
+
+static int ofilm_499_v0_unprepare(struct drm_panel *panel)
+{
+	struct ofilm_499_v0 *ctx = to_ofilm_499_v0(panel);
+	struct device *dev = &ctx->dsi->dev;
+	int ret;
+
+	ret = ofilm_499_v0_off(ctx);
+	if (ret < 0)
+		dev_err(dev, "Failed to un-initialize panel: %d\n", ret);
+
+	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+
+	return 0;
+}
