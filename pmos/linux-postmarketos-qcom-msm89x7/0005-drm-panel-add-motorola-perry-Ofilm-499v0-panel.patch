+struct ofilm_499_v0 {
+	struct drm_panel panel;
+	struct mipi_dsi_device *dsi;
+	struct gpio_desc *reset_gpio;
+};
+
+static inline struct ofilm_499_v0 *to_ofilm_499_v0(struct drm_panel *panel)
+{
+	return container_of_const(panel, struct ofilm_499_v0, panel);
+}
+
+static void ofilm_499_v0_reset(struct ofilm_499_v0 *ctx)
+{
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	usleep_range(1000, 2000);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 1);
+	usleep_range(10000, 11000);
+	gpiod_set_value_cansleep(ctx->reset_gpio, 0);
+	msleep(20);
+}
+
+static int ofilm_499_v0_on(struct ofilm_499_v0 *ctx)
+{
+	struct mipi_dsi_multi_context dsi_ctx = { .dsi = ctx->dsi };
+
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xff, 0xaa, 0x55, 0x25, 0x01);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xfc, 0x08);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xfc, 0x00);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x6f, 0x21);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf7, 0x01);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x6f, 0x21);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf7, 0x00);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x6f, 0x1a);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf7, 0x05);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xff, 0xaa, 0x55, 0x25, 0x00);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf0, 0x55, 0xaa, 0x52, 0x08, 0x02);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xee, 0x02);
+	mipi_dsi_msleep(&dsi_ctx, 1);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb0,
+				     0x00, 0x67, 0x00, 0x4f, 0x00, 0x71, 0x00,
+				     0x8b, 0x00, 0xa2, 0x00, 0xc9, 0x00, 0xe8,
