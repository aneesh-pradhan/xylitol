+	mipi_dsi_msleep(&dsi_ctx, 1);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb3, 0x03, 0xd2, 0x03, 0xe8);
+	mipi_dsi_msleep(&dsi_ctx, 1);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbc,
+				     0x00, 0x3c, 0x00, 0x7e, 0x00, 0x9d, 0x00,
