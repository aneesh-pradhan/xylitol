# Maintainer: Project Xylitol <xylitol@users.noreply.github.com>
#
# Custom perry-focused kernel. Based on msm89x7-mainline/linux with the xylitol
# perry DTS/panel carry. Perf patches: patches/01xx-*. See
# docs/perry-custom-kernel-plan.md.
pkgname=linux-motorola-perry
pkgver=7.0.9
pkgrel=1
pkgdesc="Mainline kernel for Motorola Moto E4 (perry / MSM8917) — xylitol carry"
arch="aarch64"
_carch="arm64"
_flavor="motorola-perry"
url="https://github.com/msm89x7-mainline/linux"
license="GPL-2.0-only"
options="!strip !check !tracedeps
	pmb:cross-native
	pmb:kconfigcheck-nftables
"
makedepends="
	bison
	clang
	findutils
	flex
	lld
	llvm
	openssl-dev
	perl
	postmarketos-installkernel
	python3
	zstd
"
_tag="$pkgver-r0"
_config="config-$_flavor.$arch"
# Local filename mirrors upstream aport so the cached tarball is reused.
source="
	linux-postmarketos-qcom-msm89x7-v$_tag.tar.gz::$url/archive/v$_tag.tar.gz
	$_config
	0001-Input-rmi_i2c-introduce-reset-GPIO-handling.patch
	0002-arm64-qcom-add-support-for-MSM8920.patch
	0003-arm64-dts-qcom-add-support-for-motorola-perry.patch
	0004-drm-panel-add-motorola-perry-Tianma-499v1-panel.patch
	0005-drm-panel-add-motorola-perry-Ofilm-499v0-panel.patch
	0006-arm64-dts-qcom-perry-select-Ofilm-499v0-panel.patch
"
builddir="$srcdir/linux-$_tag"

prepare() {
	default_prepare
	cp "$srcdir/$_config" .config
}

build() {
	unset LDFLAGS
	make ARCH="$_carch" LLVM=1 \
		KBUILD_BUILD_VERSION="$((pkgrel + 1))-perry-xylitol"
}

package() {
	mkdir -p "$pkgdir"/boot
	make zinstall modules_install dtbs_install \
		ARCH="$_carch" \
		LLVM=1 \
		INSTALL_PATH="$pkgdir"/boot \
		INSTALL_MOD_PATH="$pkgdir"/usr \
		INSTALL_MOD_STRIP=1 \
		INSTALL_DTBS_PATH="$pkgdir"/boot/dtbs
	rm -f "$pkgdir"/usr/lib/modules/*/build "$pkgdir"/usr/lib/modules/*/source

	install -D "$builddir"/include/config/kernel.release \
		"$pkgdir"/usr/share/kernel/$_flavor/kernel.release
}

