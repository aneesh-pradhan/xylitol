Subject: [PATCH] media: i2c: S5K4H8 Rockchip tables + ov5695 pad ops

Signed-off-by: Aneesh Pradhan <aneeshpradhan@acm.org>
---
 drivers/media/i2c/Kconfig  |   6 +
 drivers/media/i2c/Makefile |   1 +
 drivers/media/i2c/s5k4h8.c | 831 +++++++++++++++++++++++++++++++++++++
 3 files changed, 838 insertions(+)
 create mode 100644 drivers/media/i2c/s5k4h8.c

diff --git a/drivers/media/i2c/Kconfig b/drivers/media/i2c/Kconfig
index 5d173e0..e958757 100644
--- a/drivers/media/i2c/Kconfig
+++ b/drivers/media/i2c/Kconfig
@@ -793,6 +793,12 @@ config VIDEO_S5K6A3
 	  This is a V4L2 sensor driver for Samsung S5K6A3 raw
 	  camera sensor.
 
+config VIDEO_S5K4H8
+	tristate "Samsung S5K4H8"
+	select V4L2_CCI_I2C
+	help
+	  S5K4H8.
+
 config VIDEO_S5KJN1
 	tristate "Samsung S5KJN1 sensor support"
 	select V4L2_CCI_I2C
diff --git a/drivers/media/i2c/Makefile b/drivers/media/i2c/Makefile
index e45359e..f496602 100644
--- a/drivers/media/i2c/Makefile
+++ b/drivers/media/i2c/Makefile
@@ -130,6 +130,7 @@ obj-$(CONFIG_VIDEO_S5C73M3) += s5c73m3/
 obj-$(CONFIG_VIDEO_S5K3M5) += s5k3m5.o
 obj-$(CONFIG_VIDEO_S5K5BAF) += s5k5baf.o
