# Maintainer: Project Xylitol <xylitol@users.noreply.github.com>
# Reference: <https://postmarketos.org/devicepkg>
#
# First-class perry device package. Depends on linux-motorola-perry (xylitol
# mainline carry). P0 userspace (zram via deviceinfo, WLR env, lean presets,
# USB nosuspend) ships here — see docs/perry-custom-kernel-plan.md.
pkgname=device-motorola-perry
pkgdesc="Motorola Moto E4 (perry / XT1765, MSM8917)"
pkgver=1
pkgrel=4
url="https://github.com/aneesh-pradhan/xylitol"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	alsa-ucm-motorola-perry
	firmware-motorola-perry-nv
	firmware-qcom-adreno-a300
	firmware-qcom-msm89x7
	linux-motorola-perry
	lk2nd-msm8952
	mkbootimg
	msm-firmware-loader
	postmarketos-base
	soc-qcom-msm89x7
"
makedepends="devicepkg-dev"
source="
	deviceinfo
	modules-initfs
	50-perry-wlr.conf
	50-perry-usb-nosuspend.rules
	60-perry-emmc-scheduler.rules
	80-device-motorola-perry.preset
"

build() {
	devicepkg_build "$startdir" "$pkgname"
}

package() {
	devicepkg_package "$startdir" "$pkgname"

	# P0.3 — phoc/wlroots DSI EBUSY workaround
	install -Dm644 "$srcdir"/50-perry-wlr.conf \
		"$pkgdir"/etc/environment.d/50-perry-wlr.conf

	# P0.5 — USB gadget stay-awake for USB-net SSH
	install -Dm644 "$srcdir"/50-perry-usb-nosuspend.rules \
		"$pkgdir"/usr/lib/udev/rules.d/50-perry-usb-nosuspend.rules

	# P1.4 — eMMC mq-deadline
	install -Dm644 "$srcdir"/60-perry-emmc-scheduler.rules \
		"$pkgdir"/usr/lib/udev/rules.d/60-perry-emmc-scheduler.rules

	# P0.4 — systemd preset (no-op if units absent)
	install -Dm644 "$srcdir"/80-device-motorola-perry.preset \
		"$pkgdir"/usr/lib/systemd/system-preset/80-device-motorola-perry.preset

	# Linger for default image user (PipeWire/WirePlumber without open login)
	install -d "$pkgdir"/var/lib/systemd/linger
	touch "$pkgdir"/var/lib/systemd/linger/xylitol
}

