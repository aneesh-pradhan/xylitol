# Maintainer: Project Xylitol <xylitol@users.noreply.github.com>
#
# Phosh quick-setting plugins for separate rear + front torch toggles on perry.
# LED sysfs names (rear:lamp / front:lamp) are set by linux-motorola-perry so
# they do not match stock Phosh's single *:flash / *:torch torch manager.
#
# Tile icon: Adwaita media-flash-symbolic (installed as plugin Id icons).
pkgname=phosh-plugin-perry-torch
pkgver=1
pkgrel=3
pkgdesc="Phosh front/rear torch quick settings for Moto E4 (perry)"
url="https://github.com/aneesh-pradhan/xylitol"
arch="aarch64"
license="GPL-3.0-or-later"
depends="phosh libphosh"
makedepends="
	meson
	ninja
	libphosh-dev
	phosh-dev
	gtk+3.0-dev
	glib-dev
"
source="
	meson.build
	perry-rear-torch-quick-setting.plugin.in
	perry-front-torch-quick-setting.plugin.in
	perry-torch-led.c
	perry-torch-led.h
	phosh-plugin-perry-torch-quick-setting.c
	perry-rear-torch-quick-setting-symbolic.svg
	perry-front-torch-quick-setting-symbolic.svg
	"
options="!check"

build() {
	abuild-meson . output
	meson compile -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

