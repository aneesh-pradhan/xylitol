# Agent / editor local config (not part of the public build recipe)
CLAUDE.md
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.claude/
# Already-committed workflows stay tracked (gitignore never untracks); this
# only keeps NEW local .github/ additions out of accidental commits.
.github/

# Accidental Android tree / build artifacts (never belong in this meta-repo)
out/
.repo/
ccache/
*.img
*.img.gz
*.img.zst
*.zip
*.tar
*.tar.gz
*.sparseimage
*.bin
proprietary/
vendor/motorola/
artifacts/

# Stock dumps and device extracts
stock-*/
bugreport*/
*.bugreport
XT1765_*.xml

# Host clutter
*.log
*.tmp
.DS_Store
*~

# Kernel defconfig for linux-motorola-perry is tracked (canonical perry
# custom-kernel aport). Do not re-add it to this ignore list.
pmos/linux-motorola-perry/*.bak*
pmos/linux-motorola-perry/*bak-pre-*
