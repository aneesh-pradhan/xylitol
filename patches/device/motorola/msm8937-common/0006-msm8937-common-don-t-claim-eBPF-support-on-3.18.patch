From d51bc5bddc0065bbaccb882ccdb6a49b653c318c Mon Sep 17 00:00:00 2001
From: Aneesh Pradhan <apradhan5@horizon.csueastbay.edu>
Date: Sun, 19 Jul 2026 20:20:30 -0700
Subject: [PATCH] msm8937-common: don't claim eBPF support on 3.18
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

ro.kernel.ebpf.supported=true (54e26d2, for the staging 4.9 kernel)
overrides bpfloader's support-level detection, so it tries to load
programs on a kernel with CONFIG_BPF_SYSCALL unset, exits 2, and
init's reboot_on_failure loops the device with reason
'bpfloader-failed' (~30s cycles, pstore-confirmed on perry).

Without the prop, first_api_level=25 (< P) plus kernel < 4.9 resolves
to BpfLevel::NONE and bpfloader exits 0 without loading — the same
graceful path official LineageOS 18.1 (which does not set this prop)
uses on this exact kernel.
---
 properties.mk | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/properties.mk b/properties.mk
index e2e247f..74b45e9 100644
--- a/properties.mk
+++ b/properties.mk
@@ -43,10 +43,6 @@ PRODUCT_PROPERTY_OVERRIDES += \
 PRODUCT_PROPERTY_OVERRIDES += \
     vendor.qcom.bluetooth.soc=pronto
 
-# BPF
-PRODUCT_PROPERTY_OVERRIDES += \
-    ro.kernel.ebpf.supported=true
-
 # Camera
 PRODUCT_PROPERTY_OVERRIDES += \
     camera.disable_zsl_mode=1 \
-- 
2.53.0

