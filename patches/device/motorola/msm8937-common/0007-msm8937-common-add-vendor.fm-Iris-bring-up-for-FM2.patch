+# IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.
+#
+
+# Pronto / Iris FM bring-up for TARGET_QCOM_NO_FM_FIRMWARE devices.
+# libqcomfm_jni ctl.start's vendor.fm and polls vendor.hw.fm.init until 1.
+# No fm_qsoc_patches binary — enable the iris transport module and signal
+# success. (Stock Nougat used init.qcom.fm.sh + fm_qsoc_patches; 18.1
+# BoardConfig sets TARGET_QCOM_NO_FM_FIRMWARE := true.)
+
+setprop vendor.hw.fm.init 0
+
+echo 1 > /sys/module/radio_iris_transport/parameters/fmsmd_set
+
+setprop vendor.hw.fm.init 1
+
+exit 0
diff --git a/rootdir/etc/init.qcom.rc b/rootdir/etc/init.qcom.rc
index 9841c36..2d9c266 100644
--- a/rootdir/etc/init.qcom.rc
+++ b/rootdir/etc/init.qcom.rc
@@ -334,13 +334,21 @@ service vendor.tftp_server /vendor/bin/tftp_server
    class core
    user root
 
-# FM
-on property:hw.fm.init=0
+# FM (libqcomfm_jni uses vendor.hw.fm.* under Treble; hw.fm.* is legacy)
+on property:vendor.hw.fm.init=0
     write /sys/module/radio_iris_transport/parameters/fmsmd_set 0
 
-on property:hw.fm.init=1
+on property:vendor.hw.fm.init=1
     write /sys/module/radio_iris_transport/parameters/fmsmd_set 1
 
+# Started by FM JNI via ctl.start — sets vendor.hw.fm.init=1 (NO_FM_FIRMWARE)
+service vendor.fm /vendor/bin/init.qti.fm.sh
+    class late_start
+    user root
+    group system
+    disabled
+    oneshot
+
 # Adjust socket buffer to enlarge TCP receive window for high bandwidth
 # but only if ro.data.large_tcp_window_size property is set.
 on property:ro.data.large_tcp_window_size=true
diff --git a/sepolicy/vendor/fm_app.te b/sepolicy/vendor/fm_app.te
new file mode 100644
index 0000000..973f86f
--- /dev/null
+++ b/sepolicy/vendor/fm_app.te
@@ -0,0 +1,5 @@
+# FM2 (com.caf.fmradio) runs as vendor_fm_app. QCOM sepolicy only grants
+# system_app get_prop(vendor_fm_prop); the app domain needs it too so
+# libqcomfm_jni can read/write vendor.hw.fm.init|mode|version.
+get_prop(vendor_fm_app, vendor_fm_prop)
+set_prop(vendor_fm_app, vendor_fm_prop)
-- 
