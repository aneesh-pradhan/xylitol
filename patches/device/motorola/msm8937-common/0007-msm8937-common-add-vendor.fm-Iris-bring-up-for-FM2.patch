From 0a23ebbb905d0ca3a99662eecbd6840ed1551036 Mon Sep 17 00:00:00 2001
From: Aneesh Pradhan <apradhan5@horizon.csueastbay.edu>
Date: Mon, 20 Jul 2026 13:11:06 -0700
Subject: [PATCH] msm8937-common: add vendor.fm Iris bring-up for FM2

libqcomfm_jni ctl.start's vendor.fm and polls vendor.hw.fm.init; that
service was missing. Ship init.qti.fm.sh (NO_FM_FIRMWARE stub: enable
radio_iris_transport, set prop), Treble property triggers, and allow
vendor_fm_app get/set of vendor_fm_prop.
---
 msm8937.mk                 |  3 ++-
 rootdir/Android.mk         |  8 ++++++++
 rootdir/bin/init.qti.fm.sh | 42 ++++++++++++++++++++++++++++++++++++++
 rootdir/etc/init.qcom.rc   | 14 ++++++++++---
 sepolicy/vendor/fm_app.te  |  5 +++++
 5 files changed, 68 insertions(+), 4 deletions(-)
 create mode 100755 rootdir/bin/init.qti.fm.sh
 create mode 100644 sepolicy/vendor/fm_app.te

diff --git a/msm8937.mk b/msm8937.mk
index 5ce2e03..b069060 100644
--- a/msm8937.mk
+++ b/msm8937.mk
@@ -318,7 +318,8 @@ PRODUCT_PACKAGES += \
 PRODUCT_PACKAGES += \
     init.qcom.early_boot.sh \
     init.qcom.post_boot.sh \
-    init.qcom.sh
+    init.qcom.sh \
+    init.qti.fm.sh
 
 # Recovery
 PRODUCT_PACKAGES += \
diff --git a/rootdir/Android.mk b/rootdir/Android.mk
index 2b18d97..dd78ab6 100644
--- a/rootdir/Android.mk
+++ b/rootdir/Android.mk
@@ -87,6 +87,14 @@ LOCAL_SRC_FILES := bin/init.qcom.sh
 LOCAL_VENDOR_MODULE := true
 include $(BUILD_PREBUILT)
 
+include $(CLEAR_VARS)
+LOCAL_MODULE := init.qti.fm.sh
+LOCAL_MODULE_TAGS := optional
+LOCAL_MODULE_CLASS := EXECUTABLES
+LOCAL_SRC_FILES := bin/init.qti.fm.sh
+LOCAL_VENDOR_MODULE := true
+include $(BUILD_PREBUILT)
+
 include $(CLEAR_VARS)
 LOCAL_MODULE := init.qcom.rc
 LOCAL_MODULE_TAGS := optional
diff --git a/rootdir/bin/init.qti.fm.sh b/rootdir/bin/init.qti.fm.sh
new file mode 100755
index 0000000..b7b110d
--- /dev/null
+++ b/rootdir/bin/init.qti.fm.sh
@@ -0,0 +1,42 @@
