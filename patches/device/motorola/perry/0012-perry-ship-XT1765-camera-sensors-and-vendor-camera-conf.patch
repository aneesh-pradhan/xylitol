From 565193c9cd7c780ff6023de46c8c8a266cf20fc0 Mon Sep 17 00:00:00 2001
From: Aneesh Pradhan <apradhan5@horizon.csueastbay.edu>
Date: Mon, 20 Jul 2026 11:11:38 -0700
Subject: [PATCH] perry: ship XT1765 camera sensors and vendor camera conf

Extract imx219/s5k4h8/mot_ov5695_l5695fa0/dw9718s from stock
NCQS26.69-64-21; drop montana s5k3p3/s5k3p8sp leftovers. Install
camera XMLs to /vendor/etc/camera/ as msm8937_mot_camera_conf.xml
(montana sensor_modules path). Omit EepromName to avoid montana
eeprom_process SEGV (fault 0x1) until eeprom path is fixed.
---
 camera-vendor.mk                            |   2 +-
 configs/camera/msm8917_mot_perry_camera.xml |   5 +-
 device.mk                                   |   8 +-
 proprietary-files.txt                       | 164 ++++++++------------
 4 files changed, 74 insertions(+), 105 deletions(-)

diff --git a/camera-vendor.mk b/camera-vendor.mk
index f433a2e..1f9a686 100644
--- a/camera-vendor.mk
+++ b/camera-vendor.mk
@@ -5,7 +5,7 @@
 # msm8937 camera platform stack. Perry has no perry-specific copy of these
 # blobs; source them from the montana proprietary tree (same SoC family).
 # Sensor/chromatix libs stay in perry-vendor.mk / proprietary-files.txt
-# (XT1765 uses imx219/s5k4h8/mot_ov5695 — still need a stock re-extract).
+# (XT1765 imx219/s5k4h8/mot_ov5695_l5695fa0 from NCQS26.69-64-21 stock).
 #
 # Phase 0 (2026-07-19): confirmed hw_get_module looks up camera.msm8937.so
 # and opens it once SELinux labels it vendor_file.
diff --git a/configs/camera/msm8917_mot_perry_camera.xml b/configs/camera/msm8917_mot_perry_camera.xml
index 48226c5..a737754 100644
--- a/configs/camera/msm8917_mot_perry_camera.xml
+++ b/configs/camera/msm8917_mot_perry_camera.xml
@@ -87,7 +87,8 @@ LensInfo : Information of the lens present in the module.
   <CameraModuleConfig>
     <CameraId>0</CameraId>
     <SensorName>s5k4h8</SensorName>
-    <EepromName>s5k4h8</EepromName>
+    <!-- EepromName omitted: montana libmmcamera2_sensor_modules eeprom_process
+         SEGV (fault 0x1) with XT1765 eeprom libs; sensors still probe. -->
     <ActuatorName>dw9718s</ActuatorName>
     <FlashName>pmic</FlashName>
     <ChromatixName>s5k4h8_chromatix</ChromatixName>
@@ -136,7 +137,7 @@ LensInfo : Information of the lens present in the module.
   <CameraModuleConfig>
     <CameraId>1</CameraId>
     <SensorName>mot_ov5695</SensorName>
-    <EepromName>ov5695</EepromName>
+    <!-- EepromName omitted: same montana eeprom_process SEGV as back camera. -->
     <FlashName>pmic</FlashName>
     <ChromatixName>mot_ov5695_l5695fa0_chromatix</ChromatixName>
     <ModesSupported>1</ModesSupported>
diff --git a/device.mk b/device.mk
index 59a4e5d..b61d43e 100644
--- a/device.mk
+++ b/device.mk
@@ -41,10 +41,10 @@ PRODUCT_PACKAGES += \
     libppeiscore_shim
 
