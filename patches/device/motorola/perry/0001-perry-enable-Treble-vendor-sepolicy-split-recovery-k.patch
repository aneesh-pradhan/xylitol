From 334e42445707328307b8a90219f82200d63b4dc0 Mon Sep 17 00:00:00 2001
From: xylitol <xylitol@localhost>
Date: Sun, 19 Jul 2026 13:40:57 -0700
Subject: [PATCH 1/3] perry: enable Treble vendor sepolicy split, recovery
 kernel config

- Split BOARD_SEPOLICY_DIRS into BOARD_VENDOR_SEPOLICY_DIRS pointing at
  sepolicy/vendor, matching the sepolicy/ -> sepolicy/vendor/ move.
- Add TARGET_KERNEL_RECOVERY_CONFIG := perry_recovery_defconfig, following
  the cedric/hannah 17.1->18.1 pattern. UNVERIFIED: no literal
  *_recovery_defconfig fragment exists on disk for cedric or hannah either
  in kernel/motorola/msm8953's arch/arm/configs, so this presumably resolves
  through a merge_config-style mechanism not yet traced. First place to look
  if the recovery kernel build fails.
- Switch the vendor BoardConfigVendor.mk include from -include to include:
  cedric made this same change: with an 18.1 platform layer, the vendor
  config is no longer optional.

Reference: moto-msm89xx/android_device_motorola_cedric and
android_device_motorola_hannah, lineage-17.1..lineage-18.1.
---
 BoardConfig.mk | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/BoardConfig.mk b/BoardConfig.mk
index c433765..c51dfa8 100644
--- a/BoardConfig.mk
+++ b/BoardConfig.mk
@@ -22,6 +22,7 @@ TARGET_SCREEN_DENSITY := 420
 TARGET_CUSTOM_DTBTOOL := dtbTool_custom
 BOARD_DTBTOOL_ARGS := --force-v3 --motorola 1
 TARGET_KERNEL_CONFIG := perry_defconfig
+TARGET_KERNEL_RECOVERY_CONFIG := perry_recovery_defconfig
 
 # Partitions
 BOARD_RECOVERYIMAGE_PARTITION_SIZE := 16879616
@@ -31,7 +32,7 @@ BOARD_USERDATAIMAGE_PARTITION_SIZE := 10768858112
 VENDOR_SECURITY_PATCH := 2019-08-01
 
 # SELinux
-BOARD_SEPOLICY_DIRS += $(DEVICE_PATH)/sepolicy
+BOARD_VENDOR_SEPOLICY_DIRS += $(DEVICE_PATH)/sepolicy/vendor
 
 # Inherit from the proprietary version
--include vendor/motorola/montana/BoardConfigVendor.mk
+include vendor/motorola/montana/BoardConfigVendor.mk
-- 
