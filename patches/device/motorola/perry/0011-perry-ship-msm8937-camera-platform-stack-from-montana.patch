diff --git a/device.mk b/device.mk
index 9747e4a..59a4e5d 100644
--- a/device.mk
+++ b/device.mk
@@ -15,6 +15,10 @@ PRODUCT_OTA_ENFORCE_VINTF_KERNEL_REQUIREMENTS := false
 # Get non-open-source specific aspects
 $(call inherit-product-if-exists, vendor/motorola/perry/perry-vendor.mk)
 
+# msm8937 camera platform stack (HAL + mm-qcamera + MCT/ISP). Sourced from
+# montana proprietary — perry has no local copy. See camera-vendor.mk.
+$(call inherit-product, $(LOCAL_PATH)/camera-vendor.mk)
+
 # Boot animation
 TARGET_SCREEN_HEIGHT := 1280
 TARGET_SCREEN_WIDTH := 720
