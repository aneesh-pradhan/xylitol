+
+	struct v4l2_subdev sd;
+	struct media_pad pad;
+	struct v4l2_ctrl_handler ctrl_handler;
+	struct v4l2_ctrl *exposure;
+	struct v4l2_ctrl *again;
+	struct v4l2_ctrl *vblank;
+	struct v4l2_ctrl *hblank;
+	struct v4l2_ctrl *link_freq;
+	struct v4l2_ctrl *pixel_rate;
+	const struct s5k4h8_mode *cur_mode;
+	struct mutex mutex; /* Protects streaming and active format */
+	bool global_inited;
+};
+
+static int s5k4h8_power_on(struct device *dev)
+{
+	struct v4l2_subdev *sd = dev_get_drvdata(dev);
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+	int ret;
+
+	ret = regulator_bulk_enable(S5K4H8_NUM_SUPPLIES, s5k4h8->supplies);
+	if (ret)
+		return ret;
+
+	ret = clk_prepare_enable(s5k4h8->mclk);
+	if (ret)
+		goto disable_regs;
+
+	/* Release XSHUTDOWN (active-low). */
+	gpiod_set_value_cansleep(s5k4h8->reset_gpio, 0);
+	fsleep(10 * USEC_PER_MSEC);
+
+	s5k4h8->global_inited = false;
+	return 0;
+
+disable_regs:
+	regulator_bulk_disable(S5K4H8_NUM_SUPPLIES, s5k4h8->supplies);
+	return ret;
+}
+
+static int s5k4h8_power_off(struct device *dev)
+{
+	struct v4l2_subdev *sd = dev_get_drvdata(dev);
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+
+	gpiod_set_value_cansleep(s5k4h8->reset_gpio, 1);
+	clk_disable_unprepare(s5k4h8->mclk);
+	regulator_bulk_disable(S5K4H8_NUM_SUPPLIES, s5k4h8->supplies);
+	s5k4h8->global_inited = false;
+	return 0;
+}
+
+static int s5k4h8_identify(struct s5k4h8 *s5k4h8)
+{
+	u64 val = 0;
+	int ret;
+
+	ret = cci_read(s5k4h8->regmap, S5K4H8_REG_CHIP_ID, &val, NULL);
+	if (ret)
+		return ret;
+
+	if (val != S5K4H8_CHIP_ID) {
+		dev_err(s5k4h8->dev, "chip id 0x%04llx (want 0x%04x)\n",
+			val, S5K4H8_CHIP_ID);
+		return -ENODEV;
+	}
+
+	dev_info(s5k4h8->dev, "Detected S5K4H8 sensor (id 0x%04x)\n",
+		 S5K4H8_CHIP_ID);
+	return 0;
+}
+
+static int s5k4h8_write_globals(struct s5k4h8 *s5k4h8)
+{
+	int ret = 0;
+
+	if (s5k4h8->global_inited)
+		return 0;
+
+	cci_multi_reg_write(s5k4h8->regmap, s5k4h8_global_regs,
+			    ARRAY_SIZE(s5k4h8_global_regs), &ret);
+	if (!ret)
+		s5k4h8->global_inited = true;
+	return ret;
+}
+
+static int s5k4h8_set_ctrl(struct v4l2_ctrl *ctrl)
+{
+	struct s5k4h8 *s5k4h8 = container_of(ctrl->handler, struct s5k4h8,
+					     ctrl_handler);
+	s64 max;
+	int ret = 0;
+
+	if (ctrl->id == V4L2_CID_VBLANK) {
+		max = s5k4h8->cur_mode->height + ctrl->val - S5K4H8_EXPOSURE_MARGIN;
+		__v4l2_ctrl_modify_range(s5k4h8->exposure, S5K4H8_EXPOSURE_MIN,
+					 max, 1, min_t(s64, s5k4h8->exposure->val, max));
+	}
+
+	if (pm_runtime_get_if_in_use(s5k4h8->dev) <= 0)
+		return 0;
+
+	switch (ctrl->id) {
+	case V4L2_CID_EXPOSURE:
+		cci_write(s5k4h8->regmap, S5K4H8_REG_EXPOSURE, ctrl->val, &ret);
+		break;
+	case V4L2_CID_ANALOGUE_GAIN:
+		cci_write(s5k4h8->regmap, S5K4H8_REG_AGAIN, ctrl->val, &ret);
+		break;
+	case V4L2_CID_VBLANK:
+		cci_write(s5k4h8->regmap, S5K4H8_REG_VTS,
+			  s5k4h8->cur_mode->height + ctrl->val, &ret);
+		break;
+	default:
+		break;
+	}
+
+	pm_runtime_put(s5k4h8->dev);
+	return ret;
+}
+
+static const struct v4l2_ctrl_ops s5k4h8_ctrl_ops = {
+	.s_ctrl = s5k4h8_set_ctrl,
+};
+
+static int s5k4h8_init_controls(struct s5k4h8 *s5k4h8)
+{
+	struct v4l2_fwnode_device_properties props;
+	const struct s5k4h8_mode *mode = s5k4h8->cur_mode;
+	struct v4l2_ctrl_handler *hdl = &s5k4h8->ctrl_handler;
+	s64 exposure_max, vblank_def, hblank;
+	int ret;
+
+	ret = v4l2_ctrl_handler_init(hdl, 8);
+	if (ret)
+		return ret;
+	hdl->lock = &s5k4h8->mutex;
+
+	s5k4h8->link_freq = v4l2_ctrl_new_int_menu(hdl, NULL, V4L2_CID_LINK_FREQ,
+						   0, 0, s5k4h8_link_freq_menu);
+	if (s5k4h8->link_freq)
+		s5k4h8->link_freq->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	s5k4h8->pixel_rate = v4l2_ctrl_new_std(hdl, NULL, V4L2_CID_PIXEL_RATE,
+					       0, S5K4H8_PIXEL_RATE, 1,
+					       S5K4H8_PIXEL_RATE);
+
+	hblank = mode->hts_def - mode->width;
+	s5k4h8->hblank = v4l2_ctrl_new_std(hdl, NULL, V4L2_CID_HBLANK,
+					   hblank, hblank, 1, hblank);
+	if (s5k4h8->hblank)
+		s5k4h8->hblank->flags |= V4L2_CTRL_FLAG_READ_ONLY;
+
+	vblank_def = mode->vts_def - mode->height;
+	s5k4h8->vblank = v4l2_ctrl_new_std(hdl, &s5k4h8_ctrl_ops, V4L2_CID_VBLANK,
+					   vblank_def, S5K4H8_VTS_MAX - mode->height,
+					   1, vblank_def);
+
+	exposure_max = mode->vts_def - S5K4H8_EXPOSURE_MARGIN;
+	s5k4h8->exposure = v4l2_ctrl_new_std(hdl, &s5k4h8_ctrl_ops, V4L2_CID_EXPOSURE,
+					     S5K4H8_EXPOSURE_MIN, exposure_max, 1,
+					     mode->exp_def);
+
+	s5k4h8->again = v4l2_ctrl_new_std(hdl, &s5k4h8_ctrl_ops, V4L2_CID_ANALOGUE_GAIN,
+					  S5K4H8_GAIN_MIN, S5K4H8_GAIN_MAX, 1,
+					  S5K4H8_GAIN_DEFAULT);
+
+	if (hdl->error) {
+		ret = hdl->error;
+		goto err_free;
+	}
+
+	ret = v4l2_fwnode_device_parse(s5k4h8->dev, &props);
+	if (ret)
+		goto err_free;
+
+	ret = v4l2_ctrl_new_fwnode_properties(hdl, &s5k4h8_ctrl_ops, &props);
+	if (ret)
+		goto err_free;
+
+	s5k4h8->sd.ctrl_handler = hdl;
+	return 0;
+
+err_free:
+	v4l2_ctrl_handler_free(hdl);
+	return ret;
+}
+
+static void s5k4h8_update_pad_format(const struct s5k4h8_mode *mode,
+				     struct v4l2_mbus_framefmt *fmt)
+{
+	fmt->code = MEDIA_BUS_FMT_SGRBG10_1X10;
+	fmt->width = mode->width;
+	fmt->height = mode->height;
+	fmt->field = V4L2_FIELD_NONE;
+	fmt->colorspace = V4L2_COLORSPACE_RAW;
+	fmt->ycbcr_enc = V4L2_YCBCR_ENC_DEFAULT;
+	fmt->quantization = V4L2_QUANTIZATION_FULL_RANGE;
+	fmt->xfer_func = V4L2_XFER_FUNC_NONE;
+}
+
+static int s5k4h8_set_pad_format(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *state,
+				 struct v4l2_subdev_format *fmt)
+{
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+	const struct s5k4h8_mode *mode;
+	struct v4l2_mbus_framefmt *format;
+	s64 hblank, vblank_def, exposure_max;
+
+	mode = v4l2_find_nearest_size(s5k4h8_modes, ARRAY_SIZE(s5k4h8_modes),
+				      width, height,
+				      fmt->format.width, fmt->format.height);
+
+	s5k4h8_update_pad_format(mode, &fmt->format);
+	format = v4l2_subdev_state_get_format(state, 0);
+	*format = fmt->format;
+
+	if (fmt->which == V4L2_SUBDEV_FORMAT_ACTIVE) {
+		s5k4h8->cur_mode = mode;
+
+		hblank = mode->hts_def - mode->width;
+		__v4l2_ctrl_modify_range(s5k4h8->hblank, hblank, hblank, 1, hblank);
+
+		vblank_def = mode->vts_def - mode->height;
+		__v4l2_ctrl_modify_range(s5k4h8->vblank, vblank_def,
+					 S5K4H8_VTS_MAX - mode->height, 1,
+					 vblank_def);
+
+		exposure_max = mode->vts_def - S5K4H8_EXPOSURE_MARGIN;
+		__v4l2_ctrl_modify_range(s5k4h8->exposure, S5K4H8_EXPOSURE_MIN,
+					 exposure_max, 1,
+					 min_t(s64, mode->exp_def, exposure_max));
+	}
+
+	return 0;
+}
+
+static int s5k4h8_enum_mbus_code(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *sd_state,
+				 struct v4l2_subdev_mbus_code_enum *code)
+{
+	if (code->index > 0)
+		return -EINVAL;
+
+	code->code = MEDIA_BUS_FMT_SGRBG10_1X10;
+	return 0;
+}
+
+static int s5k4h8_enum_frame_size(struct v4l2_subdev *sd,
+				  struct v4l2_subdev_state *sd_state,
+				  struct v4l2_subdev_frame_size_enum *fse)
+{
+	if (fse->index >= ARRAY_SIZE(s5k4h8_modes) ||
+	    fse->code != MEDIA_BUS_FMT_SGRBG10_1X10)
+		return -EINVAL;
+
+	fse->min_width = s5k4h8_modes[fse->index].width;
+	fse->max_width = s5k4h8_modes[fse->index].width;
+	fse->min_height = s5k4h8_modes[fse->index].height;
+	fse->max_height = s5k4h8_modes[fse->index].height;
+	return 0;
+}
+
+static int s5k4h8_get_selection(struct v4l2_subdev *sd,
+				struct v4l2_subdev_state *state,
+				struct v4l2_subdev_selection *sel)
+{
+	struct v4l2_mbus_framefmt *fmt;
+
+	switch (sel->target) {
+	case V4L2_SEL_TGT_CROP:
+		fmt = v4l2_subdev_state_get_format(state, 0);
+		sel->r.top = 0;
+		sel->r.left = 0;
+		sel->r.width = fmt->width;
+		sel->r.height = fmt->height;
+		return 0;
+
+	case V4L2_SEL_TGT_NATIVE_SIZE:
+	case V4L2_SEL_TGT_CROP_DEFAULT:
+	case V4L2_SEL_TGT_CROP_BOUNDS:
+		sel->r.top = 0;
+		sel->r.left = 0;
+		sel->r.width = S5K4H8_NATIVE_WIDTH;
+		sel->r.height = S5K4H8_NATIVE_HEIGHT;
+		return 0;
+	}
+
+	return -EINVAL;
+}
+
+static int s5k4h8_enable_streams(struct v4l2_subdev *sd,
+				 struct v4l2_subdev_state *state, u32 pad,
+				 u64 streams_mask)
+{
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+	int ret;
+
+	ret = pm_runtime_resume_and_get(s5k4h8->dev);
+	if (ret < 0)
+		return ret;
+
+	ret = s5k4h8_write_globals(s5k4h8);
+	if (ret)
+		goto err_pm;
+
+	cci_multi_reg_write(s5k4h8->regmap, s5k4h8->cur_mode->reg_list,
+			    s5k4h8->cur_mode->num_regs, &ret);
+	if (ret)
+		goto err_pm;
+
+	ret = __v4l2_ctrl_handler_setup(s5k4h8->sd.ctrl_handler);
+	if (ret)
+		goto err_pm;
+
+	cci_write(s5k4h8->regmap, S5K4H8_REG_CTRL_MODE,
+		  S5K4H8_MODE_STREAMING, &ret);
+	if (ret)
+		goto err_pm;
+
+	return 0;
+
+err_pm:
+	pm_runtime_put(s5k4h8->dev);
+	return ret;
+}
+
+static int s5k4h8_disable_streams(struct v4l2_subdev *sd,
+				  struct v4l2_subdev_state *state, u32 pad,
+				  u64 streams_mask)
+{
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+
+	cci_write(s5k4h8->regmap, S5K4H8_REG_CTRL_MODE, S5K4H8_MODE_STANDBY,
+		  NULL);
+	pm_runtime_put_autosuspend(s5k4h8->dev);
+	return 0;
+}
+
+static int s5k4h8_init_state(struct v4l2_subdev *sd,
+			     struct v4l2_subdev_state *state)
+{
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+	struct v4l2_subdev_format fmt = {
+		.which = V4L2_SUBDEV_FORMAT_TRY,
+		.pad = 0,
+		.format = {
+			.width = s5k4h8->cur_mode->width,
+			.height = s5k4h8->cur_mode->height,
+		},
+	};
+
+	return s5k4h8_set_pad_format(sd, state, &fmt);
+}
+
+static const struct v4l2_subdev_video_ops s5k4h8_video_ops = {
+	.s_stream = v4l2_subdev_s_stream_helper,
+};
+
+static const struct v4l2_subdev_pad_ops s5k4h8_pad_ops = {
+	.enum_mbus_code = s5k4h8_enum_mbus_code,
+	.enum_frame_size = s5k4h8_enum_frame_size,
+	.get_fmt = v4l2_subdev_get_fmt,
+	.set_fmt = s5k4h8_set_pad_format,
+	.get_selection = s5k4h8_get_selection,
+	.enable_streams = s5k4h8_enable_streams,
+	.disable_streams = s5k4h8_disable_streams,
+};
+
+static const struct v4l2_subdev_ops s5k4h8_subdev_ops = {
+	.video = &s5k4h8_video_ops,
+	.pad = &s5k4h8_pad_ops,
+};
+
+static const struct v4l2_subdev_internal_ops s5k4h8_internal_ops = {
+	.init_state = s5k4h8_init_state,
+};
+
+static const struct media_entity_operations s5k4h8_entity_ops = {
+	.link_validate = v4l2_subdev_link_validate,
+};
+
+static int s5k4h8_check_hwcfg(struct s5k4h8 *s5k4h8)
+{
+	struct fwnode_handle *endpoint;
+	struct v4l2_fwnode_endpoint bus_cfg = {
+		.bus_type = V4L2_MBUS_CSI2_DPHY,
+	};
+	unsigned long freq_bitmap;
+	int ret;
+
+	endpoint = fwnode_graph_get_next_endpoint(dev_fwnode(s5k4h8->dev), NULL);
+	if (!endpoint)
+		return -EINVAL;
+
+	ret = v4l2_fwnode_endpoint_alloc_parse(endpoint, &bus_cfg);
+	fwnode_handle_put(endpoint);
+	if (ret)
+		return ret;
+
+	if (bus_cfg.bus.mipi_csi2.num_data_lanes != S5K4H8_DATA_LANES) {
+		dev_err(s5k4h8->dev, "expected %u data lanes, got %u\n",
+			S5K4H8_DATA_LANES, bus_cfg.bus.mipi_csi2.num_data_lanes);
+		ret = -EINVAL;
+		goto out_free;
+	}
+
+	ret = v4l2_link_freq_to_bitmap(s5k4h8->dev, bus_cfg.link_frequencies,
+				       bus_cfg.nr_of_link_frequencies,
+				       s5k4h8_link_freq_menu,
+				       ARRAY_SIZE(s5k4h8_link_freq_menu),
+				       &freq_bitmap);
+
+out_free:
+	v4l2_fwnode_endpoint_free(&bus_cfg);
+	return ret;
+}
+
+static int s5k4h8_probe(struct i2c_client *client)
+{
+	struct s5k4h8 *s5k4h8;
+	unsigned long mclk_rate;
+	unsigned int i;
+	int ret;
+
+	s5k4h8 = devm_kzalloc(&client->dev, sizeof(*s5k4h8), GFP_KERNEL);
+	if (!s5k4h8)
+		return -ENOMEM;
+
+	s5k4h8->dev = &client->dev;
+	s5k4h8->cur_mode = &s5k4h8_modes[1]; /* prefer full-res 3264x2448 */
+	v4l2_i2c_subdev_init(&s5k4h8->sd, client, &s5k4h8_subdev_ops);
+	s5k4h8->sd.internal_ops = &s5k4h8_internal_ops;
+
+	s5k4h8->regmap = devm_cci_regmap_init_i2c(client, 16);
+	if (IS_ERR(s5k4h8->regmap))
+		return dev_err_probe(s5k4h8->dev, PTR_ERR(s5k4h8->regmap),
+				     "failed to init CCI regmap\n");
+
+	s5k4h8->mclk = devm_v4l2_sensor_clk_get(s5k4h8->dev, NULL);
+	if (IS_ERR(s5k4h8->mclk))
+		return dev_err_probe(s5k4h8->dev, PTR_ERR(s5k4h8->mclk),
+				     "failed to get mclk\n");
+
+	mclk_rate = clk_get_rate(s5k4h8->mclk);
+	if (mclk_rate != S5K4H8_MCLK_FREQ)
+		return dev_err_probe(s5k4h8->dev, -EINVAL,
+				     "mclk rate must be %lu Hz, got %lu\n",
+				     S5K4H8_MCLK_FREQ, mclk_rate);
+
+	ret = s5k4h8_check_hwcfg(s5k4h8);
+	if (ret)
+		return dev_err_probe(s5k4h8->dev, ret, "invalid hardware config\n");
+
+	s5k4h8->reset_gpio = devm_gpiod_get(s5k4h8->dev, "reset", GPIOD_OUT_HIGH);
+	if (IS_ERR(s5k4h8->reset_gpio))
+		return dev_err_probe(s5k4h8->dev, PTR_ERR(s5k4h8->reset_gpio),
+				     "failed to get reset-gpios\n");
+
+	for (i = 0; i < S5K4H8_NUM_SUPPLIES; i++)
+		s5k4h8->supplies[i].supply = s5k4h8_supply_names[i];
+
+	ret = devm_regulator_bulk_get(s5k4h8->dev, S5K4H8_NUM_SUPPLIES,
+				      s5k4h8->supplies);
+	if (ret)
+		return dev_err_probe(s5k4h8->dev, ret, "failed to get regulators\n");
+
+	dev_set_drvdata(s5k4h8->dev, &s5k4h8->sd);
+
+	ret = s5k4h8_power_on(s5k4h8->dev);
+	if (ret)
+		return ret;
+
+	ret = s5k4h8_identify(s5k4h8);
+	if (ret)
+		goto err_power;
+
+	mutex_init(&s5k4h8->mutex);
+
+	ret = s5k4h8_init_controls(s5k4h8);
+	if (ret)
+		goto err_destroy_mutex;
+
+	s5k4h8->sd.flags |= V4L2_SUBDEV_FL_HAS_DEVNODE;
+	s5k4h8->sd.entity.ops = &s5k4h8_entity_ops;
+	s5k4h8->sd.entity.function = MEDIA_ENT_F_CAM_SENSOR;
+	s5k4h8->pad.flags = MEDIA_PAD_FL_SOURCE;
+
+	ret = media_entity_pads_init(&s5k4h8->sd.entity, 1, &s5k4h8->pad);
+	if (ret)
+		goto err_ctrls;
+
+	s5k4h8->sd.state_lock = s5k4h8->ctrl_handler.lock;
+	ret = v4l2_subdev_init_finalize(&s5k4h8->sd);
+	if (ret)
+		goto err_entity;
+
+	ret = v4l2_async_register_subdev_sensor(&s5k4h8->sd);
+	if (ret)
+		goto err_subdev;
+
+	pm_runtime_set_active(s5k4h8->dev);
+	pm_runtime_enable(s5k4h8->dev);
+	pm_runtime_set_autosuspend_delay(s5k4h8->dev, 1000);
+	pm_runtime_use_autosuspend(s5k4h8->dev);
+	pm_runtime_idle(s5k4h8->dev);
+
+	return 0;
+
+err_subdev:
+	v4l2_subdev_cleanup(&s5k4h8->sd);
+err_entity:
+	media_entity_cleanup(&s5k4h8->sd.entity);
+err_ctrls:
+	v4l2_ctrl_handler_free(&s5k4h8->ctrl_handler);
+err_destroy_mutex:
+	mutex_destroy(&s5k4h8->mutex);
+err_power:
+	s5k4h8_power_off(s5k4h8->dev);
+	return ret;
+}
+
+static void s5k4h8_remove(struct i2c_client *client)
+{
+	struct v4l2_subdev *sd = i2c_get_clientdata(client);
+	struct s5k4h8 *s5k4h8 = to_s5k4h8(sd);
+
+	v4l2_async_unregister_subdev(sd);
+	v4l2_subdev_cleanup(sd);
+	media_entity_cleanup(&sd->entity);
+	v4l2_ctrl_handler_free(&s5k4h8->ctrl_handler);
+	mutex_destroy(&s5k4h8->mutex);
