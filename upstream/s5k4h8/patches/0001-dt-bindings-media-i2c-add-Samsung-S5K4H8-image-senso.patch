From c34ec3377ee4de37915b658bae450893cc2dc3b3 Mon Sep 17 00:00:00 2001
From: Aneesh Pradhan <aneeshpradhan@acm.org>
Date: Thu, 23 Jul 2026 01:34:39 -0700
Subject: [PATCH 1/2] dt-bindings: media: i2c: add Samsung S5K4H8 image sensor

Document the Samsung S5K4H8 8MP CMOS image sensor. The sensor uses a
CCI (I2C-compatible) control bus and a 4-lane MIPI CSI-2 data interface
with a 24 MHz external clock.

Signed-off-by: Aneesh Pradhan <aneeshpradhan@acm.org>
---
 .../bindings/media/i2c/samsung,s5k4h8.yaml    | 113 ++++++++++++++++++
 1 file changed, 113 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/media/i2c/samsung,s5k4h8.yaml

diff --git a/Documentation/devicetree/bindings/media/i2c/samsung,s5k4h8.yaml b/Documentation/devicetree/bindings/media/i2c/samsung,s5k4h8.yaml
new file mode 100644
index 000000000000..876d09e0d0b3
--- /dev/null
+++ b/Documentation/devicetree/bindings/media/i2c/samsung,s5k4h8.yaml
@@ -0,0 +1,113 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/media/i2c/samsung,s5k4h8.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Samsung S5K4H8 Image Sensor
+
+maintainers:
+  - Aneesh Pradhan <aneeshpradhan@acm.org>
+
+description:
+  The Samsung S5K4H8 is an 8 megapixel CMOS image sensor with an MIPI CSI-2
+  interface and CCI (I2C-compatible) control bus. The sensor supports a
+  native output of 3264x2448 RAW10 on a 4-lane MIPI D-PHY link at 280 MHz
+  (560 Mbps/lane) with a 24 MHz external clock.
+
+allOf:
+  - $ref: /schemas/media/video-interface-devices.yaml#
+
+properties:
+  compatible:
+    const: samsung,s5k4h8
+
+  reg:
+    maxItems: 1
+    description: I2C device address.
+
+  clocks:
+    maxItems: 1
+    description: External master clock (MCLK / XVCLK), 24 MHz.
+
+  reset-gpios:
+    maxItems: 1
+    description:
+      GPIO connected to the sensor XSHUTDOWN / RESET pad. Active low.
+
+  avdd-supply:
+    description: Analogue voltage supply (typically 2.8 V).
+
+  dovdd-supply:
+    description: Digital I/O voltage supply (typically 1.8 V).
+
+  dvdd-supply:
+    description: Digital core voltage supply (typically 1.2 V).
+
+  port:
+    $ref: /schemas/graph.yaml#/$defs/port-base
+    additionalProperties: false
+
+    properties:
+      endpoint:
+        $ref: /schemas/media/video-interfaces.yaml#
+        unevaluatedProperties: false
+
+        properties:
+          data-lanes:
+            items:
+              - const: 1
+              - const: 2
+              - const: 3
+              - const: 4
+
+          link-frequencies: true
+
+        required:
+          - data-lanes
+          - link-frequencies
+
+required:
+  - compatible
+  - reg
+  - clocks
+  - reset-gpios
+  - avdd-supply
+  - dovdd-supply
+  - dvdd-supply
+  - port
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        camera@2d {
+            compatible = "samsung,s5k4h8";
+            reg = <0x2d>;
+
+            clocks = <&gcc 0>;
+            assigned-clocks = <&gcc 0>;
+            assigned-clock-rates = <24000000>;
+
+            reset-gpios = <&gpio 35 GPIO_ACTIVE_LOW>;
+
+            avdd-supply = <&vreg_2p8>;
+            dovdd-supply = <&vreg_1p8>;
+            dvdd-supply = <&vreg_1p2>;
+
+            port {
+                endpoint {
+                    remote-endpoint = <&csi_ep>;
+                    data-lanes = <1 2 3 4>;
+                    link-frequencies = /bits/ 64 <280000000>;
+                };
+            };
+        };
+    };
+...
-- 
