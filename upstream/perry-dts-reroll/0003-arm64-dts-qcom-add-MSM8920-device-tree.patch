From 040b9a8e4516d22bc24580f45b49700644523490 Mon Sep 17 00:00:00 2001
From: "Catherine Frederick (coolguy)" <serenity@floorchan.org>
Date: Wed, 22 Jul 2026 14:17:02 -0700
Subject: [PATCH 3/4] arm64: dts: qcom: add MSM8920 device tree

MSM8920 is essentially MSM8917 with MSM8953's modem stack. Relative to
MSM8917 it adds an IPA (IP Accelerator) block for the modem datapath and
switches the RPM clock controller compatible to "qcom,rpmcc-msm8920".

msm8920.dtsi includes msm8917.dtsi and adds the IPA node
(ipa@7900000, disabled by default) with its non-secure modem IOMMU
context, and the rpmcc-msm8920 compatible. The IPA integration mirrors
the already in-tree msm8940.dtsi; the IPA-lite v2.6 block is common
across the msm89xx family and sits at the same address.

The reserved-memory size overrides from the original submission were
dropped: on the current base they are byte-for-byte identical to
msm8917.dtsi's defaults, and the msm8940.dtsi reference does not
override them either.

Signed-off-by: Catherine Frederick (coolguy) <serenity@floorchan.org>
[aneesh: drop redundant reserved-memory overrides, relicense GPL-2.0-only
 to match msm8917.dtsi, confirm IPA/MSS against in-tree msm8940.dtsi]
Signed-off-by: Aneesh Pradhan <aneeshpradhan@acm.org>
---
 arch/arm64/boot/dts/qcom/msm8920.dtsi | 35 +++++++++++++++++++++++++++
 1 file changed, 35 insertions(+)
 create mode 100644 arch/arm64/boot/dts/qcom/msm8920.dtsi

diff --git a/arch/arm64/boot/dts/qcom/msm8920.dtsi b/arch/arm64/boot/dts/qcom/msm8920.dtsi
new file mode 100644
index 000000000000..041a085c8eed
--- /dev/null
+++ b/arch/arm64/boot/dts/qcom/msm8920.dtsi
@@ -0,0 +1,35 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Copyright (c) 2023, Dang Huynh <danct12@riseup.net>
+ * Copyright (c) 2026, Aneesh Pradhan <aneeshpradhan@acm.org>
+ */
+
+#include "msm8917.dtsi"
+
+&apps_iommu {
+	/* IPA */
+	iommu-ctx@18000 {
+		compatible = "qcom,msm-iommu-v1-ns";
+		reg = <0x18000 0x1000>;
+		interrupts = <GIC_SPI 115 IRQ_TYPE_LEVEL_HIGH>;
+	};
+};
+
+&rpmcc {
+	compatible = "qcom,rpmcc-msm8920", "qcom,rpmcc";
+};
+
+&soc {
+	ipa: ipa@7900000 {
+		compatible = "qcom,ipa-lite-v2.6";
+		reg = <0x7900000 0x47000>;
+		clocks = <&rpmcc RPM_SMD_IPA_CLK>;
+		interrupts = <GIC_SPI 228 IRQ_TYPE_EDGE_RISING>,
+			     <GIC_SPI 230 IRQ_TYPE_LEVEL_HIGH>;
+		interrupt-names = "ipa", "dma";
+		iommus = <&apps_iommu 0x18>;
+		modem-remoteproc = <&modem>;
+
+		status = "disabled";
+	};
+};
-- 
